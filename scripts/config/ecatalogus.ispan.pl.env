
# Example configuration for install/deploy scripts
# Edit and save as scripts/config/<domain>.env or pass path to scripts

DOMAIN=ecatalogus.ispan.pl
DEPLOY_USER=ispan
REPO_URL=https://github.com/TutajITeraz/eCatalogus
GIT_BRANCH=main
APPDIR=/home/${DEPLOY_USER}/domains/${DOMAIN}/ecatalogus
VENV_PATH=${APPDIR}/.venv
SERVICE_SHORTNAME=ecatalogus
SOCKET_PATH=/home/${DEPLOY_USER}/domains/${DOMAIN}/public_html/gunicorn.sock
# If you prefer TCP: set USE_TCP=1 and set PORT
USE_TCP=0
PORT=8001

# Comma-separated list of files to preserve across git resets (relative to APPDIR)
PRESERVE_FILES=settings.py,local_settings.py,config.js

# Paths for static/media
STATIC_DIR=${APPDIR}/static_assets
PUBLIC_HTML=/home/${DEPLOY_USER}/domains/${DOMAIN}/public_html

# Log directory (created if missing)
LOG_DIR=${APPDIR}/logs

# Django settings module to use for the service (optional)
DJANGO_SETTINGS_MODULE=ecatalogus.settings_ecatalogus
# Example config for install/deploy scripts
# Save as scripts/config/<domain>.env or scripts/config/default.env