# Example configuration for install/deploy scripts
# Copy this file to scripts/config/<domain>.env and edit values.
#
# Notes:
# - Set SERVICE_SHORTNAME to a short identifier for the instance (e.g. "mpl" or "ecatalogus").
#   The scripts will generate and manage a systemd unit named: gunicorn_${SERVICE_SHORTNAME}.service
#   Do NOT include the "gunicorn_" prefix in SERVICE_SHORTNAME; the prefix is added automatically.
# - By default the installer uses a Unix socket under the domain's public_html. If you prefer TCP,
#   set USE_TCP=1 and provide a free PORT. The installer will check port availability.

DOMAIN=example.com
DEPLOY_USER=ispan
REPO_URL=git@github.com:yourorg/ecatalogus.git
GIT_BRANCH=main
# Full path where the app will be checked out or updated
APPDIR=/home/${DEPLOY_USER}/domains/${DOMAIN}/ecatalogus
# Virtualenv path (defaults to ${APPDIR}/.venv)
VENV_PATH=${APPDIR}/.venv
# Short name for the instance (no 'gunicorn_' prefix)
SERVICE_SHORTNAME=mpl
# Socket path (recommended). Will be used when USE_TCP=0
SOCKET_PATH=/home/${DEPLOY_USER}/domains/${DOMAIN}/public_html/gunicorn.sock
# If you prefer TCP, set USE_TCP=1 and choose an unused PORT
USE_TCP=0
PORT=

# Comma-separated list of files to preserve across git resets (relative to APPDIR)
PRESERVE_FILES=settings.py,local_settings.py,config.js

# Paths for static/media and public_html
STATIC_DIR=${APPDIR}/static_assets
PUBLIC_HTML=/home/${DEPLOY_USER}/domains/${DOMAIN}/public_html

# Log directory (created if missing)
LOG_DIR=${APPDIR}/logs

# Django settings module to export during manage commands (optional)
DJANGO_SETTINGS_MODULE=ecatalogus.settings
